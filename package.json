{
  "name": "lawhelper-attorney-app",
  "version": "1.0.0",
  "description": "LawHelper Attorney App - Legal Practice Management System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run build:frontend",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:api && npm run test:frontend",
    "test:api": "node server/tests/api.test.js",
    "test:frontend": "node frontend/tests/frontend.test.js",
    "db:init": "node database/init.js",
    "db:migrate": "node database/migrate.js",
    "db:migrate:up": "node database/migrate.js up",
    "db:migrate:down": "node database/migrate.js down",
    "db:migrate:status": "node database/migrate.js status",
    "db:reset": "node database/reset.js",
    "db:seed": "node database/seed.js",
    "db:status": "node database/status.js",
    "smoke-test": "node lawhelper_smoke_test_framework.js",
    "verify:integration": "node scripts/verify-integration.js",
    "test:api": "node scripts/test-integration-api.js",
    "monitor:api": "node server/monitoring/api-monitor.js",
    "monitor:db": "node database/monitor.js",
    "monitor:frontend": "node frontend/monitoring/frontend-monitor.js",
    "cache:clear": "rm -rf node_modules/.cache && rm -rf frontend/node_modules/.cache"
  },
  "keywords": [
    "attorney",
    "legal",
    "law",
    "practice-management",
    "case-management",
    "client-management"
  ],
  "author": "LawHelper Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "connect-pg-simple": "^8.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pg-pool": "^3.6.1",
    "sharp": "^0.32.4",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "eslint": "^8.45.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
