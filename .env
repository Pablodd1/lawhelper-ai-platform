# LawHelper Attorney App - Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database Configuration (Fixed for local development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lawhelper_db

# JWT Configuration
JWT_SECRET=lawhelper-super-secret-jwt-key-2024-make-it-long-and-random-for-security
SESSION_SECRET=lawhelper-super-secret-session-key-2024-for-user-sessions

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AI Integration (Optional)
OPENAI_API_KEY=your-openai-api-key-here

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Security Configuration
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/application.log